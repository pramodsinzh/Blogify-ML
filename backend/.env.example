# Server
PORT=3001

# JWT Secret (use a strong random string in production)
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production

# Admin credentials (admin login / JWT issuance)
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=your-secure-password

# MongoDB — connection string WITHOUT database name (db name is appended in code)
MONGODB_URI=mongodb://127.0.0.1:27017
# Database name for this project (separate from original Blogify)
MONGODB_DB_NAME=blogify-ml

# Contact form: where to receive messages (defaults to ADMIN_EMAIL if not set)
CONTACT_EMAIL=admin@example.com

# ImageKit (https://imagekit.io)
IMAGEKIT_PUBLIC_KEY=your_imagekit_public_key
IMAGEKIT_PRIVATE_KEY=your_imagekit_private_key
IMAGEKIT_URL_ENDPOINT=https://ik.imagekit.io/your_imagekit_id

# Google Gemini (optional — blog content generation)
GEMINI_API_KEY=your_gemini_api_key

# App name (used for DB name fallback and labels)
APP_NAME=blogify-ml

# Frontend URL (emails / Inngest links)
FRONTEND_URL=http://localhost:5173

# Inngest app id — use a NEW app in Inngest dashboard for Blogify-ML (not the old Blogify app)
INNGEST_APP_ID=blogify-ml

# SMTP (e.g. Brevo, SendGrid, etc.)
SMTP_HOST=smtp.example.com
SENDER_EMAIL=noreply@example.com
SMTP_PORT=587
SMTP_USER=your_smtp_username
SMTP_PASS=your_smtp_password

# Clerk (https://clerk.com)
CLERK_PUBLISHABLE_KEY=pk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
CLERK_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ML service — local: http://localhost:8000 | production: https://your-app.onrender.com
ML_SERVICE_URL=http://localhost:8000

# Inngest (https://www.inngest.com)
INNGEST_EVENT_KEY=your_inngest_event_key
INNGEST_SIGNING_KEY=your_inngest_signing_key
