# Server
PORT=3001

# JWT Secret (use a strong random string in production)
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production

# Admin credentials (admin login / JWT issuance)
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=your-secure-password

# MongoDB (database name /blogify is appended in code)
MONGODB_URI=mongodb://localhost:27017

# Contact form: where to receive messages (defaults to ADMIN_EMAIL if not set)
CONTACT_EMAIL=admin@example.com

# ImageKit (https://imagekit.io)
IMAGEKIT_PUBLIC_KEY=your_imagekit_public_key
IMAGEKIT_PRIVATE_KEY=your_imagekit_private_key
IMAGEKIT_URL_ENDPOINT=https://ik.imagekit.io/your_imagekit_id

# Google Gemini (optional — blog content generation)
GEMINI_API_KEY=your_gemini_api_key

# App name (used where a short app label is needed)
APP_NAME=blogify

# SMTP (e.g. Brevo, SendGrid, etc.)
SMTP_HOST=smtp.example.com
SENDER_EMAIL=noreply@example.com
SMTP_PORT=587
SMTP_USER=your_smtp_username
SMTP_PASS=your_smtp_password

# Clerk (https://clerk.com)
CLERK_PUBLISHABLE_KEY=pk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
CLERK_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Inngest (https://www.inngest.com)
INNGEST_EVENT_KEY=your_inngest_event_key
INNGEST_SIGNING_KEY=your_inngest_signing_key
